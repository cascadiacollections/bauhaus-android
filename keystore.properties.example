# Copy this file to keystore.properties (which is gitignored) for local signed builds.
# Generate a keystore with:
#   keytool -genkey -v -keystore bauhaus-release.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias bauhaus
#
# Then set the values below and place the .jks file relative to the project root.

storeFile=bauhaus-release.jks
storePassword=<your-keystore-password>
keyAlias=bauhaus
keyPassword=<your-key-password>
